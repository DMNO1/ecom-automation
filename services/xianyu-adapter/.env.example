# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=true

# CORS配置
CORS_ORIGINS=["*"]

# 数据库配置
DATABASE_URL=sqlite:///./xianyu.db

# 浏览器配置
HEADLESS=true
BROWSER_TIMEOUT=30000

# 自动回复配置
AUTO_REPLY_INTERVAL=30
AI_API_KEY=your_openai_api_key_here
AI_MODEL=gpt-3.5-turbo
AI_MAX_TOKENS=1000
AI_TEMPERATURE=0.7

# 订单监控配置
ORDER_MONITOR_INTERVAL=60

# 文件存储路径
DATA_DIR=./data
COOKIES_DIR=./data/cookies
LOGS_DIR=./data/logs
SCREENSHOTS_DIR=./data/screenshots