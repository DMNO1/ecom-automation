# 竞品爬虫服务环境变量配置
# 复制此文件为 .env 并修改配置

# MongoDB配置
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=competitor_crawler

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# 爬虫配置
CRAWLER_TIMEOUT=30
CRAWLER_MAX_RETRIES=3
CRAWLER_CONCURRENCY=5
CRAWLER_REQUEST_DELAY_MIN=1
CRAWLER_REQUEST_DELAY_MAX=3

# 调度器配置
SCHEDULER_MAX_TASKS=100
SCHEDULER_TASK_TIMEOUT=300
SCHEDULER_PRICE_INTERVAL=15
SCHEDULER_TITLE_INTERVAL=30
SCHEDULER_FULL_INTERVAL=60

# 存储配置
STORAGE_DATA_DIR=./data
STORAGE_LOG_DIR=./logs
STORAGE_RETENTION_DAYS=90

# 代理配置
PROXY_ENABLED=false
PROXY_TYPE=http
PROXY_URL=
PROXY_USERNAME=
PROXY_PASSWORD=

# 通知配置
# Webhook
NOTIFICATION_WEBHOOK_ENABLED=false
NOTIFICATION_WEBHOOK_URL=

# 邮件
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_EMAIL_SMTP_HOST=
NOTIFICATION_EMAIL_SMTP_PORT=587
NOTIFICATION_EMAIL_USERNAME=
NOTIFICATION_EMAIL_PASSWORD=
NOTIFICATION_EMAIL_FROM=
NOTIFICATION_EMAIL_TO=

# 钉钉
NOTIFICATION_DINGTALK_ENABLED=false
NOTIFICATION_DINGTALK_WEBHOOK_URL=
NOTIFICATION_DINGTALK_SECRET=

# 企业微信
NOTIFICATION_WECHAT_WORK_ENABLED=false
NOTIFICATION_WECHAT_WORK_WEBHOOK_URL=
