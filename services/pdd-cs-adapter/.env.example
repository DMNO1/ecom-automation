# 拼多多客服自动化服务环境变量示例
# 复制此文件为 .env 并填入实际值

# 应用配置
DEBUG=false
HOST=0.0.0.0
PORT=8000

# 拼多多API配置
PDD_CLIENT_ID=your_client_id_here
PDD_CLIENT_SECRET=your_client_secret_here
PDD_ACCESS_TOKEN=your_access_token_here
PDD_API_BASE_URL=https://gw-api.pinduoduo.com/api/router

# 消息轮询间隔（秒）
POLL_INTERVAL=30

# 自动回复配置
AUTO_REPLY_ENABLED=true
AUTO_REPLY_DELAY=2.0

# Playwright配置
BROWSER_HEADLESS=true
PDD_WORKBENCH_URL=https://mms.pinduoduo.com
PDD_USERNAME=your_username_here
PDD_PASSWORD=your_password_here

# 数据库配置
DATABASE_URL=sqlite:///./pdd_cs.db

# Redis配置（可选）
REDIS_URL=redis://localhost:6379/0

# 知识库配置
KNOWLEDGE_BASE_PATH=./knowledge_base.json

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=./logs/service.log
