# ============================================
# Hermes 多平台电商自动化系统 - 环境变量配置
# ============================================

# 数据库配置
DB_PASSWORD=ecom2024

# 抖店开放平台
DOUYIN_APP_KEY=your_douyin_app_key
DOUYIN_APP_SECRET=your_douyin_app_secret

# 快手开放平台
KUAISHOU_APP_KEY=your_kuaishou_app_key
KUAISHOU_APP_SECRET=your_kuaishou_app_secret

# 拼多多开放平台
PDD_CLIENT_ID=your_pdd_client_id
PDD_CLIENT_SECRET=your_pdd_client_secret

# 闲鱼配置（浏览器自动化）
XIANYU_COOKIE=your_xianyu_cookie

# n8n配置
N8N_USER=admin
N8N_PASSWORD=n8n2024

# AI配置（Hermes使用）
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# 通知配置
WECHAT_WEBHOOK_URL=your_wechat_webhook
FEISHU_WEBHOOK_URL=your_feishu_webhook
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Redis配置
REDIS_URL=redis://localhost:6379

# API网关配置
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
API_GATEWORKERS=4

# 日志级别
LOG_LEVEL=INFO

# 环境
ENV=development
